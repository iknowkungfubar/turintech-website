  /* --- Site Footer --- */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-16) 0 var(--space-8);
    background: var(--color-surface);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    line-height: 0;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    display: block;
  }

