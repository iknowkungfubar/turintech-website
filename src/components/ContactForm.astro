---
export interface Props {
  webhookUrl?: string;
}

const { webhookUrl = 'http://100.106.72.45:3456/lead' } = Astro.props;
---

<form class="contact-form" id="contact-form" action={webhookUrl} method="POST" enctype="application/x-www-form-urlencoded">
  <div class="form-field">
    <label for="name" class="form-label">Name</label>
    <input type="text" id="name" name="name" class="form-input" required autocomplete="name" placeholder="Your full name" />
  </div>

  <div class="form-field">
    <label for="email" class="form-label">Email</label>
    <input type="email" id="email" name="email" class="form-input" required autocomplete="email" placeholder="you@company.com" />
  </div>

  <div class="form-field">
    <label for="message" class="form-label">Message</label>
    <textarea id="message" name="message" class="form-input form-textarea" required placeholder="Tell us about your project..." rows="5"></textarea>
  </div>

  <div class="cf-turnstile" data-sitekey="0x4AAAAAADPbMUArDsI64JW1" data-callback="onTurnstileLoad" data-size="normal"></div>

  <input type="hidden" name="cf-turnstile-response" id="cf-turnstile-response" value="" />

  <button type="submit" class="btn btn-primary form-submit" id="form-submit">Send Message</button>

  <p class="form-status" id="form-status" aria-live="polite"></p>
</form>

<script>
  (function () {
    'use strict';

    const form = document.getElementById('contact-form');
    if (!form) return;

    const hiddenTokenInput = document.getElementById('cf-turnstile-response');
    const statusEl = document.getElementById('form-status');

    let turnstileToken = '';

    window.onTurnstileLoad = function (token) {
      turnstileToken = token;
      hiddenTokenInput.value = token;
    };

    form.addEventListener('submit', function (e) {
      const name = form.querySelector('#name').value.trim();
      const email = form.querySelector('#email').value.trim();
      const message = form.querySelector('#message').value.trim();

      if (!turnstileToken) {
        e.preventDefault();
        setStatus('Please complete the verification.', 'error');
        return;
      }

      if (!name || !email || !message) {
        e.preventDefault();
        setStatus('Please fill in all required fields.', 'error');
        return;
      }

      // Form submits naturally as POST to the webhook URL
      // HTML form POST from HTTPS to HTTP is allowed (unlike fetch)
      setStatus('Sending...', '');
    });

    // After successful submission, the page shows the raw response
    // Redirect back to contact page after 3 seconds if we see the response
    if (window.location.search.includes('submitted=true')) {
      setStatus('Thanks for reaching out!', 'success');
    }

    function setStatus(message, type) {
      statusEl.textContent = message;
      statusEl.className = 'form-status' + (type ? ' form-status--' + type : '');
    }
  })();
</script>

<style>
  .contact-form {
    max-width: 560px;
  }

  .form-field {
    margin-bottom: var(--space-6);
  }

  .form-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .form-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: 8px;
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }

  .form-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    margin-top: var(--space-4);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    font-size: var(--text-sm);
    margin-top: var(--space-4);
    margin-bottom: 0;
    min-height: 1.5em;
  }

  .form-status--success {
    color: #16a34a;
  }

  .form-status--error {
    color: #dc2626;
  }
</style>