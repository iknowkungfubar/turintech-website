---
export interface Props {
  webhookUrl?: string;
}

const { webhookUrl = 'http://100.106.72.45:3456/lead' } = Astro.props;
---

<form class="contact-form" id="contact-form" data-webhook={webhookUrl}>
  <div class="form-field">
    <label for="name" class="form-label">Name</label>
    <input type="text" id="name" name="name" class="form-input" required autocomplete="name" placeholder="Your full name" />
  </div>

  <div class="form-field">
    <label for="email" class="form-label">Email</label>
    <input type="email" id="email" name="email" class="form-input" required autocomplete="email" placeholder="you@company.com" />
  </div>

  <div class="form-field">
    <label for="message" class="form-label">Message</label>
    <textarea id="message" name="message" class="form-input form-textarea" required placeholder="Tell us about your project..." rows="5" maxlength="2000"></textarea>
    <span class="form-hint" id="message-count">2,000 characters remaining</span>
  </div>

  <button type="submit" class="btn btn-primary form-submit" id="form-submit">Send Message</button>

  <p class="form-status" id="form-status" aria-live="polite"></p>
</form>

<script>
  (function () {
    'use strict';

    const form = document.getElementById('contact-form');
    if (!form) return;

    const submitBtn = document.getElementById('form-submit');
    const statusEl = document.getElementById('form-status');
    const messageEl = document.getElementById('message');
    const countEl = document.getElementById('message-count');
    const apiUrl = form.getAttribute('data-webhook');
    let submitting = false;

    // Character counter
    if (messageEl && countEl) {
      messageEl.addEventListener('input', function () {
        var remaining = 2000 - this.value.length;
        countEl.textContent = remaining.toLocaleString() + ' characters remaining';
        countEl.className = 'form-hint' + (remaining < 100 ? ' form-hint--warning' : '');
      });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (submitting) return;

      var name = form.querySelector('#name').value.trim();
      var email = form.querySelector('#email').value.trim();
      var message = messageEl.value.trim();
      var errors = [];

      if (!name) errors.push('Please enter your name.');
      if (!email) errors.push('Please enter your email address.');
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push('Please enter a valid email address.');
      if (!message) errors.push('Please enter a message.');

      if (errors.length) {
        setStatus(errors[0], 'error');
        return;
      }

      submitting = true;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      setStatus('', '');

      fetch(apiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, email: email, message: message })
      })
        .then(function (r) {
          if (r.ok) {
            setStatus('Thank you for reaching out. A member of our team will review your message and respond promptly.', 'success');
            form.reset();
            if (countEl) { countEl.textContent = '2,000 characters remaining'; countEl.className = 'form-hint'; }
          } else {
            return r.text().then(function (t) { throw new Error(t || 'Submission failed'); });
          }
        })
        .catch(function () {
          setStatus('We encountered an issue. Please try again or contact us directly.', 'error');
        })
        .finally(function () {
          submitting = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        });
    });

    function setStatus(message, type) {
      statusEl.textContent = message;
      statusEl.className = 'form-status' + (type ? ' form-status--' + type : '');
      statusEl.setAttribute('role', type === 'error' ? 'alert' : 'status');
    }
  })();
</script>

<style>
  .contact-form {
    max-width: 560px;
  }

  .form-field {
    margin-bottom: var(--space-6);
  }

  .form-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .form-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: 8px;
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }

  .form-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    margin-top: var(--space-4);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    font-size: var(--text-sm);
    margin-top: var(--space-4);
    margin-bottom: 0;
    min-height: 1.5em;
  }

  .form-status--success {
    color: #16a34a;
  }

  .form-status--error {
    color: #dc2626;
  }
  .form-hint {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--space-1);
    text-align: right;
    transition: color var(--transition-fast);
  }
  .form-hint--warning {
    color: #f59e0b;
  }
</style>