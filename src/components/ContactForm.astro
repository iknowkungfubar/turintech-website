---
export interface Props {
  webhookUrl?: string;
}

// webhookUrl from Astro.props or PUBLIC_WEBHOOK_URL env var
// Falls back to FormSubmit.co for static GitHub Pages hosting.
const { webhookUrl = import.meta.env.PUBLIC_WEBHOOK_URL || '' } = Astro.props;
const formAction = webhookUrl || 'https://formsubmit.co/josh@turintechsolutions.com';
---

<form class="contact-form" id="contact-form" action={formAction} method="POST">
  <!-- Honeypot: hidden field that bots fill, humans don't -->
  <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

  <!-- Redirect back to home with success anchor -->
  <input type="hidden" name="_next" value="https://turintechsolutions.com/#contact" />
  <input type="hidden" name="_subject" value="New Contact Form Submission from turintechsolutions.com" />
  <input type="hidden" name="_captcha" value="true" />

  <div class="form-field">
    <label for="name" class="form-label">Name</label>
    <input type="text" id="name" name="name" class="form-input" required autocomplete="name" placeholder="Your full name" />
  </div>

  <div class="form-field">
    <label for="email" class="form-label">Email</label>
    <input type="email" id="email" name="email" class="form-input" required autocomplete="email" placeholder="you@company.com" />
  </div>

  <div class="form-field">
    <label for="message" class="form-label">Message</label>
    <textarea id="message" name="message" class="form-input form-textarea" required placeholder="Tell us about your project..." rows="5" maxlength="2000"></textarea>
    <span class="form-hint" id="message-count">2,000 characters remaining</span>
  </div>

  <button type="submit" class="btn btn-primary form-submit" id="form-submit">Send Message</button>

  <p class="form-status" id="form-status" aria-live="polite"></p>
</form>

<script>
  (function () {
    'use strict';

    const form = document.getElementById('contact-form');
    if (!form) return;

    const messageEl = document.getElementById('message');
    const countEl = document.getElementById('message-count');

    // Character counter
    if (messageEl && countEl) {
      messageEl.addEventListener('input', function () {
        const remaining = 2000 - (messageEl as HTMLTextAreaElement).value.length;
        countEl.textContent = remaining.toLocaleString() + ' characters remaining';
        countEl.className = 'form-hint' + (remaining < 100 ? ' form-hint--warning' : '');
      });
    }
  })();
</script>

<style>
  .contact-form { max-width: 560px; }
  .form-field { margin-bottom: var(--space-6); }
  .form-label { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--color-text); margin-bottom: var(--space-2); }
  .form-input { width: 100%; padding: var(--space-3) var(--space-4); font-family: var(--font-sans); font-size: var(--text-base); color: var(--color-text); background: var(--color-bg); border: 1px solid var(--color-border-strong); border-radius: 8px; outline: none; transition: border-color var(--transition-fast), box-shadow var(--transition-fast); }
  .form-input:focus { border-color: var(--color-accent); box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12); }
  .form-input::placeholder { color: var(--color-text-tertiary); }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-submit { margin-top: var(--space-4); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-status { font-size: var(--text-sm); margin-top: var(--space-4); margin-bottom: 0; min-height: 1.5em; }
  .form-status--success { color: var(--color-success); }
  .form-status--error { color: var(--color-error); }
  .form-hint { display: block; font-size: var(--text-xs); color: var(--color-text-tertiary); margin-top: var(--space-1); text-align: right; transition: color var(--transition-fast); }
  .form-hint--warning { color: var(--color-warning); }
</style>
