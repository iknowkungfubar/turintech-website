---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About &mdash; Expert Technical Architecture Without the Agency Bloat" description="Expert Technical Architecture. No Agency Bloat." page="about">
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">About</span>
      <h1>Expert Technical Architecture.<br /><span class="text-accent">No Agency Bloat.</span></h1>
    </div>
  </section>

  <!-- Body -->
  <section class="section">
    <div class="container">
      <div class="about-layout">
        <div class="about-content">
          <p>
            I am a solo technical architect who builds secure, privately hosted setups. I don't run a huge
            agency, and I don't hand your project off to junior developers.
          </p>
          <p>
            When you hire TurinTech Solutions, you work directly with a senior systems engineer who takes
            your data security seriously. I build private systems so your team can use powerful AI without
            ever handing your data over to a shared public platform.
          </p>
        </div>
        <div class="about-photo">
          <img src="/images/gnome-pup5.png" alt="Josh TurinTech" class="about-photo-img" />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .about-photo-img {
    width: 100%;
    max-width: 400px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .about-photo {
      order: -1;
    }
  }
</style>

<style is:global>
  /* --- Page Header --- */
  .page-header {
    padding: var(--space-16) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  /* --- Content --- */
  .about-content {
    max-width: 720px;
  }

  .about-content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }
</style>
