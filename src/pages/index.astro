---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
---

<Layout title="Strategic Technology Consulting & Infrastructure Restructuring — Build for the Future. Protect Your Data." description="Technology should accelerate business execution, not create friction. TurinTech Solutions provides comprehensive systems architecture and infrastructure modernization for growing organizations. We stabilize legacy environments and deploy secure, AI-assisted workflows that scale predictably.">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <picture>
          <source srcset={base + 'images/logo.webp'} type="image/webp" />
          <img src={base + 'images/logo-optimized.png'} alt="TurinTech Solutions" class="hero-logo" width="600" height="400" fetchpriority="high" />
        </picture>
        <span class="section-label hero-label">Strategic Technology Consulting & Infrastructure Restructuring.</span>
        <h1 class="hero-title">
          Optimize Your Technology. Build for the Future.<br />
          <span class="text-accent">Protect Your Data.</span>
        </h1>
        <p class="hero-subtitle">
          We optimize enterprise IT environments, automate operational bottlenecks, and secure cloud infrastructures.
        </p>
        <p class="hero-subtitle hero-subtitle--secondary">
          Technology should accelerate business execution, not create friction. TurinTech Solutions provides comprehensive systems architecture and infrastructure modernization for growing organizations. We stabilize legacy environments and deploy secure, AI-assisted workflows that scale predictably.
        </p>
        <div class="hero-actions">
          <a href="#services-detail" class="btn btn-primary">Explore Services</a>
          <a href="#about" class="btn btn-secondary">About Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== THE PROBLEM ===== -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">The Problem</span>
      <h2 class="section-title">Broken Architecture Blocks Scalability.</h2>
      <div class="problem-content">
        <p>
          Many organizations rush to adopt modern SaaS or AI platforms without addressing their underlying infrastructure. Disconnected identity environments, manual data pipelines, and unsecured cloud perimeters create compounding technical debt and severe operational risk.
        </p>
      </div>
      <div class="grid-3 problem-grid">
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="card-title">Systemic Disorganization</h3>
          <p class="card-text">Layering modern applications over fragile, undocumented infrastructure accelerates system failure and increases administrative overhead.</p>
        </article>
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3 class="card-title">Security & Compliance Risks</h3>
          <p class="card-text">Incomplete Role-Based Access Control (RBAC), misconfigured cloud tenants, and pasting proprietary data into public LLMs expose your organization to critical data leaks.</p>
        </article>
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="card-title">Operational Inefficiency</h3>
          <p class="card-text">When infrastructure is unstable, teams burn valuable capital executing manual data entry and reactive firefighting instead of driving business logic.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== HOW WE FIX IT ===== -->
  <section class="section">
    <div class="container">
      <div class="diff-grid">
        <div class="diff-content">
          <span class="section-label">How We Fix It</span>
          <h2 class="section-title">Secure, Reliable, and Automated Infrastructure.</h2>
          <p class="section-subtitle">
            We provide rigorous architectural oversight and hands-on execution. TurinTech Solutions audits your existing environment, enforces baseline security compliance, and integrates custom automation workflows to eliminate operational drag.
          </p>
          <ul class="diff-list">
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>Comprehensive Systems Architecture</strong>
                <span>We evaluate the complete control surface, from identity governance to endpoint management, ensuring systemic alignment.</span>
              </div>
            </li>
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>Production-Grade Execution</strong>
                <span>We handle the technical implementation. You receive deployed, documented, and fully operational systems.</span>
              </div>
            </li>
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>Future-Proof Governance</strong>
                <span>We build highly observable, strictly governed infrastructures ready to safely support advanced API integrations and private AI deployments.</span>
              </div>
            </li>
          </ul>
        </div>
        <div class="diff-visual" aria-hidden="true">
          <div class="diff-graphic">
            <div class="diff-row diff-row--bad">
              <span class="diff-label diff-label--bad">Broken Tech</span>
              <span class="diff-arrow diff-arrow--bad">&rarr;</span>
              <span class="diff-label diff-label--bad">Slower Growth</span>
            </div>
            <div class="diff-row-divider"></div>
            <div class="diff-row diff-row--good">
              <span class="diff-label diff-label--good">Clean Systems</span>
              <span class="diff-arrow diff-arrow--good">&rarr;</span>
              <span class="diff-label diff-label--good">Scalable Growth</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section-alt" id="services">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Get Started</span>
        <h2 class="cta-title">Is your technology holding your business back?</h2>
        <p class="cta-text">
          Find out with a Technology and AI Readiness Assessment. I will identify what is slowing you down and provide a step by step roadmap to get your business ready for growth.
        </p>
        <div class="cta-actions">
          <a href="#services-detail" class="btn btn-primary">Explore Services</a>
          <a href="#contact-form-section" class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section" id="services-detail">
    <div class="container">
      <span class="section-label">Our Core Consulting Services</span>
      <h2 class="section-title">Practical, high-leverage systems engineering <span class="text-accent">for modern organizations.</span></h2>
      <p class="section-subtitle">
        Contact us for pricing tailored to your requirements.
      </p>

      <!-- Service 1 -->
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <div>
            <h3>Infrastructure Audit & Security Baseline</h3>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-desc">
          <p>A rigorous review of your current cloud tenants (Microsoft 365, Azure), identity architectures, and endpoint compliance. We identify critical vulnerabilities and provide a roadmap to secure scale.</p>
        </div>
      </div>

      <hr class="section-separator service-separator" />

      <!-- Service 2 -->
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div>
            <h3>Systemic Cleanup & Cloud Migrations</h3>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-desc">
          <p>We manage the complex restructuring of legacy systems. From zero-downtime cloud migrations to enforcing strict conditional access protocols, we ensure your infrastructure is stable and compliant.</p>
        </div>
      </div>

      <hr class="section-separator service-separator" />

      <!-- Service 3 -->
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <div>
            <h3>API Integrations & Automated Data Pipelines</h3>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-desc">
          <p>We engineer secure, REST API-driven workflows connecting your disparate enterprise platforms (e.g., Salesforce, Jira, CRM). We eliminate manual data entry through resilient, error-handled automation.</p>
        </div>
      </div>

      <hr class="section-separator service-separator" />

      <!-- Service 4 -->
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </div>
          <div>
            <h3>Private AI & Knowledge Architecture</h3>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-desc">
          <p>We deploy secure, ring-fenced Retrieval-Augmented Generation (RAG) applications and internal knowledge copilots. We allow your team to leverage LLM capabilities without compromising data sovereignty or compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMMITMENT TO EFFICIENCY ===== -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Engineered for Efficiency</span>
        <h2 class="cta-title">Less talk. More building.</h2>
        <p class="cta-text">
          We respect your operational bandwidth. TurinTech Solutions operates on a documentation-first, asynchronous workflow. We minimize meeting fatigue and prioritize visible execution, providing clear architectural specs, robust failure-mode analysis, and functional deliverables.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== LET'S TALK ===== -->
  <section class="section">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Let's Talk</span>
        <h2 class="cta-title">Stabilize Your Infrastructure.</h2>
        <p class="cta-text">
          Is manual operational overhead or legacy technical debt restricting your organizational growth? Contact us to discuss your infrastructure bottlenecks and automation requirements.
        </p>
        <a href="#contact-form-section" class="btn btn-primary">Schedule a Technical Assessment</a>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <section class="section section-alt" id="contact-form-section">
    <div class="container">
      <div class="contact-section-layout">
        <span class="section-label">Contact</span>
        <h2 class="section-title contact-section-title">Reach out <span class="text-accent">today.</span></h2>
        <p class="contact-section-subtitle">
          Tell me what is slowing your business down, and we will figure out the best way forward. No pressure and no tech jargon.
        </p>
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-layout">
        <div class="about-content">
          <span class="section-label">About</span>
          <h2 class="section-title">Strategic Systems Engineering.<br /><span class="text-accent">No big agency bloat.</span></h2>
          <p>
            TurinTech Solutions is a specialized technical consultancy focused on IT modernization, identity governance, and automated systems architecture.
          </p>
          <p>
            We partner with organizations to bridge the gap between traditional IT infrastructure and modern, AI-enabled operational workflows. By enforcing strict security controls, rigorous documentation, and intelligent automation, we build environments that allow businesses to operate with absolute clarity and minimal friction.
          </p>
          <div class="about-actions">
           <!-- <a href="https://blog.turintechsolutions.com" class="btn btn-blog" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Read My Blog
            </a> -->
            <a href="#contact-form-section" class="btn btn-primary">Get in Touch</a>
          </div>
        </div>
        <div class="about-photo">
          <picture>
            <source srcset={base + 'images/logo.webp'} type="image/webp" />
            <img src={base + 'images/logo-optimized.png'} alt="TurinTech Solutions" class="hero-logo" width="600" height="400" fetchpriority="high" />
            <!-- <source srcset={base + 'images/gnome-pup5.webp'} type="image/webp" /> -->
            <!-- <img src={base + 'images/gnome-pup5.png'} alt="Josh TurinTech" class="about-photo-img" loading="lazy" width="400" height="400" /> -->
          </picture>
          <!-- <p class="about-photo-caption">Turin and Jojo. Edited and generated by Google Gemini</p> -->
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .hero { padding: var(--space-2) 0 var(--space-6); overflow: hidden; }
  .hero-content { max-width: 720px; margin: 0 auto; text-align: center; }
  .hero-logo { display: block; width: 100%; max-width: 600px; height: auto; margin: 0 auto var(--space-2); }
  @media (max-width: 640px) { .hero-logo { max-width: 90%; } .hero { padding: var(--space-1) 0 var(--space-3); } }
  .hero-label { font-size: var(--text-base); margin-bottom: var(--space-1); }
  @media (min-width: 768px) { .hero-label { font-size: var(--text-lg); margin-bottom: var(--space-2); } }
  .hero-title { font-size: clamp(1.5rem, 3.5vw, var(--text-3xl)); font-weight: 800; margin-bottom: var(--space-4); line-height: var(--leading-tight); }
  .hero-subtitle { font-size: var(--text-lg); color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--space-2); }
  .hero-subtitle--secondary { font-size: var(--text-base); margin: 0 auto var(--space-6); }
  .hero-actions { display: flex; gap: var(--space-4); flex-wrap: wrap; justify-content: center; }

  .problem-content { max-width: 720px; margin-bottom: var(--space-12); }
  .problem-content p { font-size: var(--text-lg); color: var(--color-text-secondary); }
  .problem-grid { margin-top: var(--space-8); }

  .diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: center; }
  .diff-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-6); }
  .diff-item { display: flex; gap: var(--space-4); align-items: flex-start; }
  .diff-check { color: var(--color-accent); flex-shrink: 0; margin-top: 2px; }
  .diff-item strong { display: block; font-size: var(--text-base); font-weight: 600; color: var(--color-text); margin-bottom: var(--space-1); }
  .diff-item span { font-size: var(--text-sm); color: var(--color-text-secondary); }
  .diff-visual { display: flex; justify-content: center; }
  .diff-graphic { display: flex; flex-direction: column; align-items: center; gap: var(--space-4); padding: var(--space-6) var(--space-8); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 16px; }
  .diff-row { display: flex; align-items: center; gap: var(--space-3); }
  .diff-row-divider { width: 80%; height: 1px; background: var(--color-border); }
  .diff-label { font-size: var(--text-sm); font-weight: 600; padding: var(--space-2) var(--space-4); border-radius: 8px; white-space: nowrap; }
  .diff-label--bad { color: #dc2626; background: #fef2f2; border: 1px solid #fecaca; }
  .diff-label--good { color: #16a34a; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .diff-arrow { font-size: var(--text-xl); font-weight: 300; }
  .diff-arrow--bad { color: #dc2626; }
  .diff-arrow--good { color: #16a34a; }
  @media (max-width: 768px) { .diff-grid { grid-template-columns: 1fr; gap: var(--space-8); } .diff-visual { display: none; } }

  .cta-block { text-align: center; padding: var(--space-4) 0; }
  .cta-title { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); }
  .cta-text { max-width: 520px; margin: 0 auto var(--space-8); color: var(--color-text-secondary); }
  .cta-actions { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }

  .service-detail { max-width: 960px; margin-top: var(--space-8); }
  .service-detail-header { display: flex; gap: var(--space-6); align-items: flex-start; margin-bottom: var(--space-6); }
  .service-detail-header h3 { font-size: var(--text-2xl); font-weight: 700; margin-bottom: 0; }
  .service-detail-icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 14px; background: var(--color-accent-ghost); color: var(--color-accent); flex-shrink: 0; }
  .service-detail-desc { max-width: 720px; }
  .service-detail-desc p { font-size: var(--text-base); }
  .service-separator { margin: var(--space-10) 0; }
  @media (max-width: 768px) { .service-detail-header { flex-direction: column; } }

  .contact-section-layout { max-width: 640px; }
  .contact-section-title { font-size: var(--text-4xl); }
  .contact-section-subtitle { font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-10); }

  .about-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
  .about-content p { font-size: var(--text-lg); color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-6); }
  .about-photo-img { width: 100%; max-width: 400px; border-radius: 12px; border: 1px solid var(--color-border); }
  .about-photo-caption { font-size: var(--text-xs); color: var(--color-text-tertiary); margin-top: var(--space-3); max-width: 400px; font-style: italic; }
  .about-actions { display: flex; gap: var(--space-4); margin-top: var(--space-6); flex-wrap: wrap; }
  .about-actions .btn-blog { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-6); font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 600; line-height: 1; border: 2px solid var(--color-text); border-radius: 8px; transition: all var(--transition-base); background: transparent; color: var(--color-text); text-decoration: none; }
  .about-actions .btn-blog:hover { background: var(--color-text); color: var(--color-bg); }
  @media (max-width: 768px) { .about-layout { grid-template-columns: 1fr; gap: var(--space-8); } .about-photo { order: -1; } }
</style>
