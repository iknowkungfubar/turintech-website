---
import Layout from '../layouts/Layout.astro';
const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
---

<Layout title="Sovereign AI Infrastructure — Private, Secure, Local-First" page="home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
         <img src={base + 'images/logo.png'} alt="TurinTech Solutions" class="hero-logo" />
        <span class="section-label">Sovereign AI Infrastructure</span>
<h1 class="hero-title">
           Your AI. Your Environment. Total Data Control.<br />
           <span class="text-accent">No Trade Secret Leaks.</span>
         </h1>
         <p class="hero-subtitle">
           When your employees use consumer AI chatbots, your intellectual property is at risk. We build private AI setups that run entirely within your own controlled environment, whether that is local hardware or a dedicated private cloud. You get the benefits of AI without the privacy headaches.
         </p>
        <div class="hero-actions">
           <a href={base + 'services'} class="btn btn-primary">Explore Services</a>
           <a href={base + 'about'} class="btn btn-secondary">About Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">The Problem</span>
<h2 class="section-title">Public AI is an operational liability</h2>
       <div class="problem-content">
         <p>
           Securing corporate data on public platforms means dealing with complicated enterprise contracts,
           long legal addendums, and changing state privacy laws. Worse, employees often use unapproved AI
           tools just to get their work done. This can accidentally expose your proprietary data and ruin
           your trade secret protections. Privately hosted AI solves this by keeping your data exactly
           where it belongs: inside a network you completely control.
         </p>
       </div>
      <div class="grid-3 problem-grid">
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="card-title">Legal Exposure</h3>
          <p class="card-text">DTSA protections evaporate the moment your data touches a third-party server. Public AI chatbots are a legal liability your counsel hasn't flagged.</p>
        </article>
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3 class="card-title">Regulatory Risk</h3>
          <p class="card-text">20 states now enforce strict data privacy laws. Sending internal data through public AI pipelines violates compliance frameworks you're already subject to.</p>
        </article>
        <article class="card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="card-title">IP Theft</h3>
          <p class="card-text">Every prompt you type into a public AI model trains someone else's product. Your trade secrets become their training data. Your competitive advantage, gone.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- How We Fix It -->
  <section class="section">
    <div class="container">
      <div class="diff-grid">
        <div class="diff-content">
          <span class="section-label">How We Fix It</span>
          <h2 class="section-title">Sovereign AI. Your hardware. Your data.</h2>
          <p class="section-subtitle">
            We install private AI infrastructure on your own servers — no cloud dependencies, no data leaving your network, no third parties reading your prompts.
          </p>
          <ul class="diff-list">
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>Full data sovereignty</strong>
                <span>Your IP never touches a third-party server. Ever.</span>
              </div>
            </li>
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>No monthly SaaS fees</strong>
                <span>Own your infrastructure outright. No per-seat licensing, no API markup.</span>
              </div>
            </li>
            <li class="diff-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="diff-check"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <strong>DTSA-compliant by design</strong>
                <span>Your trade secret protections remain intact. Built for legal defensibility from day one.</span>
              </div>
            </li>
          </ul>
        </div>
        <div class="diff-visual" aria-hidden="true">
          <div class="diff-graphic">
            <div class="diff-row diff-row--bad">
              <span class="diff-label diff-label--bad">Public AI</span>
              <span class="diff-arrow diff-arrow--bad">&rarr;</span>
              <span class="diff-label diff-label--bad">Data Leak</span>
            </div>
            <div class="diff-row-divider"></div>
            <div class="diff-row diff-row--good">
              <span class="diff-label diff-label--good">Sovereign AI</span>
              <span class="diff-arrow diff-arrow--good">&rarr;</span>
              <span class="diff-label diff-label--good">Protected</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Get Started</span>
        <h2 class="cta-title">Is your data leaking into public AI?</h2>
        <p class="cta-text">
          Find out with a Sovereign AI & Data Audit. I'll show you exactly where your exposure is and how to fix it.
        </p>
         <a href={base + 'services'} class="btn btn-primary">Book an Audit</a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* --- Hero --- */
  .hero {
    padding: var(--space-24) 0 var(--space-16);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  
  .hero-logo {
    display: block;
    height: 400px;
    width: auto;
    margin: 0 auto var(--space-8);
  }
  
  .hero-title {
    font-size: clamp(2.25rem, 5vw, var(--text-6xl));
    font-weight: 800;
    margin-bottom: var(--space-6);
    line-height: var(--leading-tight);
    text-align: center;
  }
  
  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8);
    text-align: center;
  }
  
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* --- Problem Section --- */
  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .problem-content {
    max-width: 720px;
    margin-bottom: var(--space-12);
  }

  .problem-content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .problem-grid {
    margin-top: var(--space-8);
  }

  /* --- Diff / Solution --- */
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .diff-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .diff-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .diff-check {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .diff-item strong {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .diff-item span {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .diff-visual {
    display: flex;
    justify-content: center;
  }

  .diff-graphic {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-8);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .diff-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .diff-row-divider {
    width: 80%;
    height: 1px;
    background: var(--color-border);
  }

  .diff-label {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-4);
    border-radius: 8px;
    white-space: nowrap;
  }

  .diff-label--bad {
    color: #dc2626;
    background: #fef2f2;
    border: 1px solid #fecaca;
  }

  .diff-label--good {
    color: #16a34a;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
  }

  .diff-arrow {
    font-size: var(--text-xl);
    font-weight: 300;
  }

  .diff-arrow--bad {
    color: #dc2626;
  }

  .diff-arrow--good {
    color: #16a34a;
  }

  @media (max-width: 768px) {
    .diff-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .diff-visual {
      display: none;
    }
  }

  /* --- CTA --- */
  .cta-block {
    text-align: center;
    padding: var(--space-8) 0;
  }

  .cta-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .cta-text {
    max-width: 480px;
    margin: 0 auto var(--space-8);
    color: var(--color-text-secondary);
  }
</style>
