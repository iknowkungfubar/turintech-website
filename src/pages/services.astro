---
import Layout from '../layouts/Layout.astro';
const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
---

<Layout title="Services — Sovereign AI, Fractional CTO, Local AI Infrastructure" page="services">
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">Services</span>
      <h1>Three ways to <span class="text-accent">lock your data down</span></h1>
      <p class="page-header-sub">
        Whether you need a full audit, ongoing technical leadership, or private AI installed on your own servers — there's a path that fits.
      </p>
    </div>
  </section>

  <!-- Service 1: Sovereign AI & Data Audits -->
  <section class="section">
    <div class="container">
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <div>
            <h2>Sovereign AI & Data Audits</h2>
            <p class="service-detail-summary"><strong>$10,000 – $25,000 Fixed Sprint</strong></p>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-body">
          <div class="service-detail-desc">
            <p>
              A top-to-bottom structural diagnostic. I find exactly where your employees are leaking
              company data into public AI models and provide a blueprint to lock your infrastructure down.
            </p>
          </div>
          <div class="service-detail-sidebar">
            <div class="service-card">
              <h4>Pricing</h4>
              <p>$10,000 – $25,000 fixed sprint. You know the cost upfront.</p>
            </div>
            <div class="service-card">
              <h4>What you get</h4>
              <p>Complete exposure map, remediation blueprint, and priority path to Sovereign AI infrastructure.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-separator" />

  <!-- Service 2: Fractional CTO Retainer -->
  <section class="section">
    <div class="container">
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div>
            <h2>Fractional CTO Retainer</h2>
            <p class="service-detail-summary"><strong>Starting at $3,000/mo</strong></p>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-body">
          <div class="service-detail-desc">
            <p>
              I act as your part-time technology leader for Seed to Series A companies. I oversee your
              infrastructure, enforce data governance, and ensure your business scales safely.
            </p>
          </div>
          <div class="service-detail-sidebar">
            <div class="service-card">
              <h4>Pricing</h4>
              <p>Starting at $3,000/month. Month-to-month. No long-term commitment.</p>
            </div>
            <div class="service-card">
              <h4>Ideal for</h4>
              <p>Seed to Series A companies that need senior technical leadership without a full-time executive salary.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-separator" />

  <!-- Service 3: Local AI Infrastructure -->
  <section class="section">
    <div class="container">
      <div class="service-detail">
        <div class="service-detail-header">
          <div class="service-detail-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <div>
            <h2>Local AI Infrastructure</h2>
            <p class="service-detail-summary"><strong>Custom Quote</strong></p>
          </div>
        </div>
        <hr class="divider" />
        <div class="service-detail-body">
          <div class="service-detail-desc">
            <p>
              I install private AI tools directly onto your company's servers. No monthly SaaS fees,
              no third-party providers reading your prompts.
            </p>
          </div>
          <div class="service-detail-sidebar">
            <div class="service-card">
              <h4>Pricing</h4>
              <p>Custom quote based on infrastructure requirements and scope.</p>
            </div>
            <div class="service-card">
              <h4>Key benefit</h4>
              <p>One-time setup. Your AI runs on your hardware. No ongoing SaaS fees. Zero data leakage.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-separator" />

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Let's Talk</span>
        <h2 class="cta-title">Not sure which fit is right for you?</h2>
        <p class="cta-text">
          Send me a message and I'll help you figure it out. No sales pitch — just a conversation about what you need.
        </p>
        <a href={base + 'contact'} class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* --- Page Header --- */
  .page-header {
    padding: var(--space-16) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  .page-header-sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
  }

  /* --- Service Detail --- */
  .service-detail {
    max-width: 960px;
  }

  .service-detail-header {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    margin-bottom: var(--space-8);
  }

  .service-detail-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .service-detail-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0;
  }

  .service-detail-summary strong {
    font-size: var(--text-lg);
    color: var(--color-accent);
  }

  .service-detail-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--color-accent-ghost);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .service-detail-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-12);
    padding-top: var(--space-8);
  }

  .service-detail-desc p {
    margin-bottom: var(--space-6);
    font-size: var(--text-base);
  }

  .service-detail-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-6);
  }

  .service-card h4 {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }

  .service-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 768px) {
    .service-detail-header {
      flex-direction: column;
    }

    .service-detail-body {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* --- CTA --- */
  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-block {
    text-align: center;
    padding: var(--space-8) 0;
  }

  .cta-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .cta-text {
    max-width: 480px;
    margin: 0 auto var(--space-8);
    color: var(--color-text-secondary);
  }
</style>
