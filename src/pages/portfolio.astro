---
import Layout from '../layouts/Layout.astro';
const _b = import.meta.env.BASE_URL;
const base = _b.endsWith('/') ? _b : _b + '/';

// Portfolio data — all 9 public repos
// shields.io badge helpers
const ghOwner = 'iknowkungfubar';
function ciBadge(repo: string) {
  return `https://github.com/${ghOwner}/${repo}/actions/workflows/ci.yml/badge.svg?branch=main`;
}
function shieldsBadge(label: string, value: string, color: string) {
  return `https://img.shields.io/badge/${label}-${value}-${color}.svg`;
}
const screenshotBase = '/images/screenshots';

// Portfolio data — all 9 public repos
const basePath = base.replace(/\/+$/, '');
const repos = [
  {
    name: 'no-slop-harness',
    screenshot: `${basePath}/images/portfolio/no-slop-harness-terminal.svg`,
    tagline: 'Deterministic LLM Orchestration via the CIV Pattern',
    description: 'A production-grade framework that enforces structured, verifiable LLM workflows. Rejects the "black-box agent" model in favor of a three-phase pipeline with explicit constraints, validated schemas, and deterministic handoffs.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['PyPI', 'CLI', 'Type Safe', 'Plugin System'],
    shields: [
      { src: ciBadge('no-slop-harness'), alt: 'CI' },
      { src: shieldsBadge('version', '0.9.1', 'blue'), alt: 'version', link: 'https://pypi.org/project/no-slop-harness/' },
      { src: shieldsBadge('license', 'Apache%202.0', 'green'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/no-slop-harness',
    package: 'https://pypi.org/project/no-slop-harness/',
    packageLabel: 'pip install no-slop-harness',
    features: [
      'CIV pipeline — Coordinator, Implementor, Verifier phases',
      'Deterministic DAG scheduling with Kahn\'s algorithm',
      'Sandboxed execution with allow/block lists',
      'AST-aware editing via tree-sitter',
      'Pydantic schema enforcement at every boundary',
    ],
    cli: `$ no-slop --help
Usage: no-slop [OPTIONS] COMMAND [ARGS]...

  No-Slop Harness — deterministic LLM orchestration.

Options:
  -v, --verbose  Enable verbose logging.
  --help         Show this message and exit.

Commands:
  init     Initialize a new CIV pipeline session.
  list     List all tasks in the current pipeline.
  status   Show the current pipeline status.
  verify   Verify a completed task.
  report   Report the result of an implemented task.`,
  },
  {
    name: 'swe-swarm',
    screenshot: `${basePath}/images/portfolio/swe-swarm-terminal.svg`,
    tagline: 'Multi-Agent SWE Orchestration Framework',
    description: 'An autonomous software development framework where specialized AI agents collaborate to build, test, and deploy code. Implements the Ralph Wiggum Loop (RWL) for continuous self-correcting development cycles.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['Multi-Agent', 'RWL', 'Dashboard'],
    shields: [
      { src: ciBadge('swe-swarm'), alt: 'CI' },
      { src: shieldsBadge('version', '0.1.0', 'blue'), alt: 'version' },
      { src: shieldsBadge('license', 'MIT', 'green'), alt: 'license' },
      { src: shieldsBadge('status', 'pre--release', 'orange'), alt: 'status' },
    ],
    github: 'https://github.com/iknowkungfubar/swe-swarm',
    package: 'https://github.com/iknowkungfubar/swe-swarm/releases',
    packageLabel: 'Install from source (pre-PyPI)',
    features: [
      'Ralph Wiggum Loop — self-correcting execution cycle',
      'Multi-team support: dev, test, deploy agents',
      'LLM provider abstraction (OpenAI, Ollama, custom)',
      'FastAPI dashboard with WebSocket monitoring',
      'YAML-based configuration per team',
    ],
    cli: `$ swe-swarm --help
usage: swe-swarm [-h] [--verbose] [--config CONFIG] [goal]

SWE Swarm — Multi-Agent SWE Orchestration

positional arguments:
  goal                  The goal for the swarm to accomplish

options:
  -h, --help            show this help message and exit
  --verbose, -v         Enable verbose logging
  --config CONFIG, -c CONFIG
                        Path to configuration file`,
  },
  {
    name: 'candor-ai',
    screenshot: `${basePath}/images/portfolio/candor-ai-terminal.svg`,
    tagline: 'Lawful Good Rust Agentic Operating System',
    description: 'A Rust-native agentic framework with 7-phase agent lifecycle, voice interaction, PDA interface, and persistent memory. Built for reliability and performance — no garbage collector, no runtime overhead.',
    language: 'Rust',
    languageColor: '#DEA584',
    badges: ['Native', 'Voice', 'Memory', 'PDA'],
    shields: [
      { src: ciBadge('candor-ai'), alt: 'CI' },
      { src: shieldsBadge('version', '0.x.x', 'blue'), alt: 'version', link: 'https://crates.io/crates/candor-ai' },
      { src: shieldsBadge('license', 'MIT', 'green'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/candor-ai',
    package: 'https://crates.io/crates/candor-ai',
    packageLabel: 'cargo install candor-ai',
    features: [
      '7-phase agent lifecycle with deterministic transitions',
      'Voice interaction pipeline (STT → LLM → TTS)',
      'PDA-style interface with gesture controls',
      'Persistent memory with vector embeddings',
      'Zero-cost abstractions via Rust ownership model',
    ],
    cli: `$ candor --help
candor-ai 0.x.x
Lawful Good Rust Agentic Operating System

USAGE:
    candor [FLAGS] [OPTIONS] [SUBCOMMAND]

FLAGS:
    -v, --verbose    Verbose logging
    -h, --help       Prints help information

SUBCOMMANDS:
    agent     Start an agent session
    config    Configure agent settings
    memory    Inspect or query agent memory`,
  },
  {
    name: 'ring-fenced-rag',
    screenshot: `${basePath}/images/portfolio/ring-fenced-rag-terminal.svg`,
    tagline: 'Self-Hosted, Zero-Trust RAG with RBAC',
    description: 'A secure Retrieval-Augmented Generation system with role-based access control enforced at the database level. Documents, chunks, and vectors are isolated by user role — no document ever leaks across trust boundaries.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['RAG', 'RBAC', 'Zero-Trust', 'Vector DB'],
    shields: [
      { src: ciBadge('ring-fenced-rag'), alt: 'CI' },
      { src: shieldsBadge('python', '3.13', 'blue'), alt: 'python' },
      { src: shieldsBadge('license', 'MIT', 'green'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/ring-fenced-rag',
    features: [
      'Row-level security enforced at the database',
      'Multi-tenant document isolation by role',
      'Local-first — no external vector API calls',
      'HNSW indexing for fast approximate nearest neighbor',
      'Audit logging for every retrieval operation',
    ],
    cli: `$ ring-fenced-rag --help
Ring-Fenced RAG — Zero-Trust Retrieval Augmented Generation

Commands:
  index     Index documents into the vector store
  query     Query the RAG system with RBAC enforcement
  serve     Start the RAG API server
  admin     Admin commands for tenant management`,
  },
  {
    name: 'autoresearch-stack',
    screenshot: `${basePath}/images/portfolio/autoresearch-stack-terminal.svg`,
    tagline: 'Autonomous LLM Training Research Stack',
    description: 'An end-to-end pipeline for autonomous ML research — from dataset curation and model training to evaluation and paper generation. Designed for reproducible, self-guided experimentation.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['Research', 'Training', 'Auto-ML'],
    shields: [
      { src: ciBadge('autoresearch-stack'), alt: 'CI' },
      { src: shieldsBadge('version', '0.7.3', 'blue'), alt: 'version', link: 'https://pypi.org/project/autoresearch-stack/' },
      { src: shieldsBadge('license', 'MIT', 'yellow'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/autoresearch-stack',
    features: [
      'Automated dataset curation and preprocessing',
      'Distributed training orchestration',
      'Experiment tracking with metrics visualization',
      'Automated hyperparameter optimization',
      'Paper generation from experiment results',
    ],
    cli: `$ autoresearch --help
Autonomous Research Stack — Self-Guided ML Research

Commands:
  init      Initialize a new research project
  dataset   Curate and preprocess datasets
  train     Start or resume model training
  evaluate  Run evaluation benchmarks
  publish   Generate research artifacts`,
  },
  {
    name: 'IronSilo',
    screenshot: `${basePath}/images/portfolio/IronSilo-terminal.svg`,
    tagline: 'Local-First AI Development Sandbox',
    description: 'A cross-platform, local-first development sandbox for AI projects. Provides containerized environments with pre-configured toolchains, GPU passthrough, and strict resource isolation — AI development without cloud dependency.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['Sandbox', 'Docker', 'GPU', 'Cross-Platform'],
    shields: [
      { src: ciBadge('IronSilo'), alt: 'CI' },
      { src: shieldsBadge('Platform', 'Linux%20%7C%20macOS%20%7C%20Windows', 'lightgrey'), alt: 'platform' },
      { src: shieldsBadge('license', 'MIT', 'blue'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/IronSilo',
    features: [
      'Docker-based isolated development environments',
      'GPU passthrough for local model training',
      'Pre-configured ML toolchains (PyTorch, TensorFlow)',
      'Resource limits and network isolation',
      'One-command environment teardown and reset',
    ],
    cli: `$ ironsilo --help
IronSilo — Local-First AI Development Sandbox

Commands:
  create    Create a new sandbox environment
  list      List active sandboxes
  exec      Execute commands inside a sandbox
  destroy   Tear down a sandbox
  config    Configure sandbox templates`,
  },
  {
    name: 'file-org-wiz',
    screenshot: `${basePath}/images/portfolio/file-org-wiz-terminal.svg`,
    tagline: 'AI-Powered File Organization System',
    description: 'Intelligent file organization using PARA methodology and Zettelkasten note-taking principles. AI classifies, tags, and structures your digital workspace automatically.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['AI', 'PARA', 'Zettelkasten', 'CLI'],
    shields: [
      { src: ciBadge('file-org-wiz'), alt: 'CI' },
      { src: shieldsBadge('python', '3.8%2B', 'green'), alt: 'python' },
      { src: shieldsBadge('license', 'MIT', 'blue'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/file-org-wiz',
    features: [
      'AI-powered file classification and tagging',
      'PARA methodology (Projects, Areas, Resources, Archives)',
      'Zettelkasten note linking for knowledge management',
      'Duplicate detection and smart merging',
      'Dry-run mode to preview changes before applying',
    ],
    cli: `$ file-org-wiz --help
File Organization Wizard — AI-Powered Digital Workspace

Commands:
  scan      Scan directory for organization
  classify  AI-classify files into categories
  organize  Apply organization rules
  graph     Show knowledge graph of linked notes
  status    Show workspace organization stats`,
  },
  {
    name: 'HALF',
    screenshot: `${basePath}/images/portfolio/HALF-terminal.svg`,
    tagline: 'Agentic Operating System',
    description: 'An agent-native operating environment that treats AI agents as first-class system processes. Provides agent lifecycle management, inter-agent communication, resource scheduling, and secure execution contexts at the OS level.',
    language: 'Python',
    languageColor: '#3572A5',
    badges: ['OS-Level', 'Agent Runtime', 'Scheduling'],
    shields: [
      { src: ciBadge('Hermes-Agentic-Lifecycle-Framework'), alt: 'CI' },
      { src: shieldsBadge('license', 'MIT', 'green'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/Hermes-Agentic-Lifecycle-Framework',
    features: [
      'Agent as a first-class OS process',
      'Inter-agent IPC with typed message passing',
      'Resource-aware agent scheduling',
      'Secure sandboxed execution contexts',
      'System-level observability and logging',
    ],
    cli: `$ half --help
HALF — Agentic Operating System

Commands:
  run       Execute an agent in a managed context
  ps        List running agent processes
  kill      Terminate an agent process
  logs      Stream agent logs
  schedule  Schedule recurring agent tasks`,
  },
  {
    name: 'turintech-website',
    tagline: 'Company Website & Product Showcase',
    description: 'This very website! Built with Astro, deployed via GitHub Pages. Static site generation for performance, dark/light mode, responsive design, and SEO-optimized. Open source — because we ship what we use.',
    language: 'Astro / JS',
    languageColor: '#BC52EE',
    badges: ['Astro', 'Static', 'Open Source', 'Dark Mode'],
    shields: [
      { src: shieldsBadge('Astro', 'v6.3.1', 'BC52EE'), alt: 'astro' },
      { src: shieldsBadge('license', 'MIT', 'green'), alt: 'license' },
    ],
    github: 'https://github.com/iknowkungfubar/turintech-website',
    features: [
      'Built with Astro v6 — fast static site generation',
      'Dark/light mode with system preference detection',
      'Responsive mobile-first design',
      'SEO-optimized with JSON-LD schema',
      'Published via GitHub Pages with zero server cost',
    ],
    cli: `$ bun run build  # Build the site
$ bun run dev      # Local dev server at :4321
$ bun run preview  # Preview production build`,
  },
];
---
<Layout title="Portfolio — Open Source Projects by TurinTech Solutions" description="Explore our portfolio of open-source AI infrastructure tools: agent frameworks, RAG systems, security sandboxes, and more.">
  <section class="section" style="text-align:center;padding:var(--space-16) 0;">
    <div class="container">
      <span class="section-label">Portfolio</span>
      <h1 class="section-title" style="margin: 0 auto var(--space-6); font-size: var(--text-4xl);">
        Open Source Infrastructure<br /><span class="text-accent">Built for Production.</span>
      </h1>
      <p style="max-width: 640px; margin: 0 auto var(--space-8); font-size: var(--text-lg);">
        Every tool here is production-tested, locally deployable, and genuinely useful. No vaporware, no abandoned side projects, no "we'll open source it later."
      </p>
    </div>
  </section>

  {
    repos.map((repo, idx) => (
      <section class={`section ${idx % 2 === 1 ? 'section-alt' : ''}`} id={repo.name}>
        <div class="container portfolio-repo">
          <div class="repo-header">
            <div class="repo-title-group">
              <h2 class="repo-name">{repo.name}</h2>
              <span class="repo-tagline">{repo.tagline}</span>
            </div>
            <div class="repo-actions">
              <a href={repo.github} class="btn btn-secondary btn-sm" target="_blank" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
              </a>
              {repo.package && (
                <a href={repo.package} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  {repo.packageLabel}
                </a>
              )}
            </div>
          </div>

          <p class="repo-description">{repo.description}</p>

          <div class="repo-meta">
            <span class="lang-badge" style={`--lang-color: ${repo.languageColor};`}>
              <span class="lang-dot"></span>
              {repo.language}
            </span>
            {repo.badges.map(badge => (
              <span class="tech-badge">{badge}</span>
            ))}
          </div>

          <div class="repo-shields">
            {repo.shields?.map(s => (
              s.link
                ? <a href={s.link} target="_blank" rel="noopener noreferrer"><img src={s.src} alt={s.alt} loading="lazy" /></a>
                : <img src={s.src} alt={s.alt} loading="lazy" />
            ))}
          </div>

          <div class="repo-screenshot">
            <a href={repo.github} target="_blank" rel="noopener noreferrer">
              <img src={basePath + '/images/screenshots/' + repo.name + '.svg'} alt={`${repo.name} CLI screenshot`} class="screenshot-img" loading="lazy" width="800" height="auto" />
            </a>
          </div>

          <div class="repo-content">
            <div class="repo-features">
              <h3 class="features-title">Key Capabilities</h3>
              <ul class="features-list">
                {repo.features.map(f => (
                  <li>{f}</li>
                ))}
              </ul>
            </div>
            <div class="repo-cli">
              <div class="cli-header">
                <span class="cli-dot cli-dot--red"></span>
                <span class="cli-dot cli-dot--yellow"></span>
                <span class="cli-dot cli-dot--green"></span>
                <span class="cli-label">Terminal</span>
              </div>
              <pre class="cli-body"><code>{repo.cli}</code></pre>
            </div>
          </div>
          </div>
      </section>
    ))
  }
</Layout>

<style is:inline>
  .portfolio-repo {
    max-width: 1000px;
  }

  .repo-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .repo-title-group {
    flex: 1;
    min-width: 0;
  }

  .repo-name {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-1);
    letter-spacing: var(--tracking-tight);
  }

  .repo-tagline {
    display: block;
    font-size: var(--text-lg);
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .repo-actions {
    display: flex;
    gap: var(--space-3);
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .btn-sm {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
  }

  .repo-description {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    max-width: 720px;
  }

  .repo-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .lang-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    border-radius: 20px;
    font-size: var(--text-xs);
    font-weight: 600;
    background: color-mix(in srgb, var(--lang-color) 12%, transparent);
    color: var(--lang-color);
    border: 1px solid color-mix(in srgb, var(--lang-color) 25%, transparent);
  }

  .lang-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lang-color);
  }

  .tech-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: 20px;
    font-size: var(--text-xs);
    font-weight: 500;
    background: var(--color-accent-ghost);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .repo-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 768px) {
    .repo-content {
      grid-template-columns: 1fr;
    }
  }

  .features-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .features-list li {
    position: relative;
    padding-left: var(--space-6);
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .features-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.6;
  }

  .repo-shields {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .repo-shields img {
    height: 20px;
    display: inline-block;
    border-radius: 3px;
  }

  .repo-screenshot {
    margin-bottom: var(--space-6);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: border-color var(--transition-base);
  }

  .repo-screenshot:hover {
    border-color: var(--color-accent);
  }

  .screenshot-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .repo-cli {
    margin-bottom: var(--space-6);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .repo-screenshot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .repo-cli {
    background: #1a1b26;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  body:not(.dark) .repo-cli {
    background: #1e1e2e;
  }

  .cli-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .cli-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .cli-dot--red { background: #ff5f56; }
  .cli-dot--yellow { background: #ffbd2e; }
  .cli-dot--green { background: #27c93f; }

  .cli-label {
    margin-left: auto;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cli-body {
    margin: 0;
    padding: 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.65;
  }

  .cli-body code {
    color: #cdd6f4;
    font-family: var(--font-mono);
    white-space: pre;
  }

  .repo-screenshot {
    margin-bottom: var(--space-8);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .screenshot-img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
  }
</style>
