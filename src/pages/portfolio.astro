---
import Layout from '../layouts/Layout.astro';
const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';

const repos = [
  {
    name: 'No-Slop Harness',
    slug: 'no-slop-harness',
    tagline: 'Deterministic, local-first LLM orchestration framework',
    description: 'Enforces structured, verifiable LLM workflows via the CIV (Coordinator-Implementor-Verifier) pattern. Rejects the black-box agent model in favor of a three-phase pipeline with explicit constraints, validated schemas, and deterministic handoffs.',
    differentiator: 'Only framework with AST-aware editing, Kahn-scheduled DAG execution, and zero external dependencies for core (pydantic + rich + click + tree-sitter only).',
    github: 'https://github.com/iknowkungfubar/no-slop-harness',
    pypi: 'https://pypi.org/project/no-slop-harness/',
    docs: 'Python — CLI',
    badges: [
      'https://img.shields.io/badge/version-0.9.1-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
      'https://github.com/iknowkungfubar/no-slop-harness/actions/workflows/ci.yml/badge.svg?branch=main',
    ],
    screenshot: `$ no-slop --help
usage: no-slop [-h] {init,run,status,list,version} ...

No-Slop Harness — Deterministic LLM Orchestration

positional arguments:
  {init,run,status,list,version}
    init        Initialize a new project
    run         Run the pipeline
    status      Show pipeline status
    list        List available pipelines
    version     Show version info`,
  },
  {
    name: 'Candor AI',
    slug: 'candor-ai',
    tagline: 'Production-grade modular agent orchestration framework',
    description: 'A comprehensive Rust ecosystem of 11 crates (core, graph, sandbox, cognitive, memory, sentinel, orchestrator, tools, mcp, telemetry) with a Tauri desktop interface and voice stack. The most engineered repo in the portfolio — 320+ tests, real-time monitoring, and plugin architecture.',
    differentiator: 'Full Rust ecosystem with Tauri desktop GUI, voice integration (speech-to-text + text-to-speech), and MCP server mode. 11 interoperable crates with sentinel security enforcement.',
    github: 'https://github.com/iknowkungfubar/candor-ai',
    crates: 'https://crates.io/crates/candor-ai',
    docs: 'Rust — CLI + Tauri Desktop',
    badges: [
      'https://img.shields.io/badge/version-0.1.0-blueviolet.svg',
      'https://img.shields.io/badge/rust-1.85+-orange.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
      'https://img.shields.io/badge/tests-320%2B-brightgreen.svg',
    ],
    screenshot: `candor-ai — Agent Orchestration
┌─────────────────────────────────────┐
│  Orchestrator  ←→  Cognitive       │
│       ↓               ↓             │
│  Sandbox      ←→    Memory          │
│       ↓               ↓             │
│  Tools        ←→   Sentinel        │
│       ↓                             │
│  Telemetry    ←→     MCP            │
└─────────────────────────────────────┘
11 crates • 320+ tests • Tauri Desktop`,
  },
  {
    name: 'SWE Swarm',
    slug: 'swe-swarm',
    tagline: 'Multi-agent SWE (Software Engineering) swarm orchestration',
    description: 'Orchestrates multiple AI agents working together on software engineering tasks. Swarm-based architecture with configurable agent roles, parallel task execution, and GitHub integration.',
    differentiator: 'Swarm intelligence for code — multiple agents collaborate with specialized roles (planner, implementer, reviewer, tester) using a shared workspace and consensus-driven output.',
    github: 'https://github.com/TurinTech-Solutions/swe-swarm',
    pypi: 'https://pypi.org/project/swe-swarm/',
    docs: 'Python — CLI',
    badges: [
      'https://img.shields.io/badge/version-0.1.0a1-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `$ swe-swarm --help
usage: swe-swarm [-h] [--verbose] [--config CONFIG] [goal]

SWE Swarm — Multi-Agent SWE Orchestration

positional arguments:
  goal                  The goal for the swarm to accomplish

options:
  -h, --help            show this help message and exit
  --verbose, -v         Enable verbose logging
  --config CONFIG, -c CONFIG
                        Path to configuration file`,
  },
  {
    name: 'Ring-Fenced RAG',
    slug: 'ring-fenced-rag',
    tagline: 'Secure, self-hosted Retrieval-Augmented Generation',
    description: 'A production-ready RAG system designed for data sovereignty. Deploy private LLM-powered document Q&A behind your own firewall with strict access controls and zero data exfiltration.',
    differentiator: 'Ring-fenced security model — documents never leave your infrastructure. Built-in access control, audit logging, and support for local LLMs (Ollama, vLLM) and cloud APIs.',
    github: 'https://github.com/TurinTech-Solutions/ring-fenced-rag',
    docs: 'Python — Web UI + API',
    badges: [
      'https://img.shields.io/badge/version-0.3.0-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `Ring-Fenced RAG — Secure Document Q&A
┌──────────────────────────────────────┐
│  Upload → Chunk → Embed → Store     │
│                           ↓          │
│  Query → Retrieve → Augment → LLM   │
│                           ↓          │
│                        Response     │
└──────────────────────────────────────┘
Local-first • Zero data exfiltration`,
  },
  {
    name: 'AutoResearch Stack',
    slug: 'autoresearch-stack',
    tagline: 'Autonomous deep research agent with iterative refinement',
    description: 'An AI-powered research agent that performs comprehensive multi-source investigation. Iteratively improves its understanding through self-critique, deep web searches, and structured reporting.',
    differentiator: 'Iterative self-refinement loop — the agent critiques its own findings, identifies knowledge gaps, and performs targeted follow-up research before producing a final report.',
    github: 'https://github.com/TurinTech-Solutions/autoresearch-stack',
    docs: 'Python — CLI',
    badges: [
      'https://img.shields.io/badge/version-0.2.0-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `AutoResearch Stack — Deep Research Agent
┌──────────────────────────────────────┐
│  Iteration 1: Initial Research      │
│  → 5 sources, broad coverage       │
│  → Self-critique: gaps detected    │
│                                     │
│  Iteration 2: Targeted Deep Dive    │
│  → 8 new sources, deep analysis    │
│  → Self-critique: confidence >90%  │
│                                     │
│  Final: Structured Report          │
│  → Executive summary + evidence    │
└──────────────────────────────────────┘
Iterative self-refinement`,
  },
  {
    name: 'IronSilo',
    slug: 'ironsilo',
    tagline: 'Security boundary enforcement and file integrity monitoring',
    description: 'A security tool for monitoring file integrity, detecting unauthorized changes, and enforcing security policies across your infrastructure. Provides tamper-evident audit trails and real-time alerts.',
    differentiator: 'Hardened security monitoring with cryptographic integrity verification, policy-as-code configuration, and integration with existing SIEM/SOAR systems.',
    github: 'https://github.com/TurinTech-Solutions/IronSilo',
    docs: 'Python — CLI',
    badges: [
      'https://img.shields.io/badge/version-0.1.0-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `IronSilo — Security Boundary Enforcement
┌──────────────────────────────────────┐
│  🔒 File Integrity Monitor          │
│  🔒 Policy Enforcement Engine       │
│  🔒 Tamper-Evident Audit Logs       │
│  🔒 Real-Time Alert Pipeline        │
└──────────────────────────────────────┘
cryptographic integrity • policy-as-code`,
  },
  {
    name: 'File Organization Wizard',
    slug: 'file-org-wiz',
    tagline: 'Rule-based file organization MCP server',
    description: 'An MCP (Model Context Protocol) server for automated file organization. Define rules to sort, rename, archive, and categorize files based on type, date, pattern matching, and custom classifiers.',
    differentiator: 'AI-native file organization via MCP protocol — works with any MCP-compatible client (Claude Desktop, code editors). Rule engine supports regex, metadata, and content-based classification.',
    github: 'https://github.com/TurinTech-Solutions/file-org-wiz',
    docs: 'Python — MCP Server',
    badges: [
      'https://img.shields.io/badge/version-0.1.0-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `$ file-org-wiz --help
usage: file-org-wiz [-h] [--host HOST] [--port PORT]
                    [--mount MOUNT] [--backup BACKUP] [--cors]

File Organization Wizard MCP Server

options:
  -h, --help       show this help message and exit
  --host HOST      Server host (default: localhost)
  --port PORT      Server port (default: 8000)
  --mount MOUNT    Directory to organize
  --backup BACKUP  Backup directory
  --cors           Enable CORS`,
  },
  {
    name: 'HALF',
    slug: 'half',
    tagline: 'Hermetic Agentic Lifecycle Framework — agentic OS',
    description: 'An experimental agentic operating system framework that provides hermetic lifecycle management for AI agents. Sandboxed environments, resource governance, and deterministic scheduling for autonomous agents.',
    differentiator: 'True OS-level agent isolation — agents run in hermetic environments with resource quotas, filesystem sandboxing, and network policy enforcement. Designed for multi-agent data centers.',
    github: 'https://github.com/TurinTech-Solutions/HALF',
    docs: 'Python — CLI + GUI',
    badges: [
      'https://img.shields.io/badge/version-0.1.0-blueviolet.svg',
      'https://img.shields.io/badge/python-3.11+-blue.svg',
      'https://img.shields.io/badge/license-Apache%202.0-green.svg',
    ],
    screenshot: `HALF — Hermetic Agentic Lifecycle Framework
┌──────────────────────────────────────┐
│  Agent Lifecycle Manager            │
│  ┌─────┐ → ┌─────┐ → ┌─────────┐  │
│  │Init │   │Run  │   │Terminate│  │
│  └─────┘   └─────┘   └─────────┘  │
│                                     │
│  → Resource Quota Enforcement      │
│  → Filesystem Sandboxing           │
│  → Network Policy Isolation        │
└──────────────────────────────────────┘
Hermetic isolation for autonomous agents`,
  },
];
---

<Layout title="Portfolio — Open Source Projects — TurinTech Solutions" description="Explore our portfolio of production-grade open source tools: LLM orchestration, agent frameworks, RAG systems, security tools, and more.">
  <!-- ===== HERO ===== -->
  <section class="portfolio-hero">
    <div class="container">
      <div class="portfolio-hero-content">
        <span class="section-label">Portfolio</span>
        <h1 class="portfolio-hero-title">
          Open Source <span class="text-accent">Infrastructure</span>
        </h1>
        <p class="portfolio-hero-subtitle">
          Production-grade tools for AI orchestration, security, automation, and
          agent lifecycle management. Every repo ships with CI/CD, tests, and documentation.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== REPO GRID ===== -->
  <section class="section">
    <div class="container">
      {
        repos.map((repo, idx) => (
          <article class={`repo-card ${idx % 2 === 1 ? 'repo-card--alt' : ''}`} id={repo.slug}>
            <div class="repo-card-inner">
              <!-- Screenshot / terminal window -->
              <div class="repo-screenshot">
                <div class="terminal-window">
                  <div class="terminal-header">
                    <div class="terminal-dot terminal-dot--red"></div>
                    <div class="terminal-dot terminal-dot--yellow"></div>
                    <div class="terminal-dot terminal-dot--green"></div>
                    <span class="terminal-title">{repo.slug}</span>
                  </div>
                  <pre class="terminal-body"><code>{repo.screenshot}</code></pre>
                </div>
              </div>

              <!-- Repo info -->
              <div class="repo-info">
                <div class="repo-meta">
                  <span class="repo-tag">{repo.docs}</span>
                </div>
                <h2 class="repo-name">{repo.name}</h2>
                <p class="repo-tagline">{repo.tagline}</p>
                <p class="repo-description">{repo.description}</p>
                <div class="repo-differentiator">
                  <strong>Key differentiator:</strong> {repo.differentiator}
                </div>

                <!-- Badges -->
                <div class="repo-badges">
                  {
                    repo.badges.map((badge) => (
                      <img src={badge} alt="" class="repo-badge" loading="lazy" />
                    ))
                  }
                </div>

                <!-- Links -->
                <div class="repo-links">
                  <a href={repo.github} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    GitHub
                  </a>
                  {
                    repo.pypi && (
                      <a href={repo.pypi} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                        PyPI
                      </a>
                    )
                  }
                  {
                    repo.crates && (
                      <a href={repo.crates} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                        crates.io
                      </a>
                    )
                  }
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-block">
        <span class="section-label">Get Involved</span>
        <h2 class="cta-title">Use what we build. <span class="text-accent">Contribute.</span></h2>
        <p class="cta-text">
          All projects are Apache 2.0 licensed. Open issues, feature requests, and pull requests welcome.
          Need something custom? Let's talk.
        </p>
        <div class="cta-actions">
          <a href="https://github.com/TurinTech-Solutions" class="btn btn-primary" target="_blank" rel="noopener noreferrer">GitHub Organization</a>
          <a href="/#contact-form-section" class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Portfolio Hero */
  .portfolio-hero {
    padding: var(--space-16) 0 var(--space-8);
    text-align: center;
  }
  .portfolio-hero-content {
    max-width: 720px;
    margin: 0 auto;
  }
  .portfolio-hero-title {
    font-size: var(--text-5xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }
  .portfolio-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Repo Card */
  .repo-card {
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .repo-card:last-child {
    border-bottom: none;
  }
  .repo-card-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }
  .repo-card--alt .repo-card-inner {
    direction: rtl;
  }
  .repo-card--alt .repo-card-inner > * {
    direction: ltr;
  }

  @media (max-width: 768px) {
    .repo-card-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .repo-card--alt .repo-card-inner {
      direction: ltr;
    }
  }

  /* Terminal Window */
  .terminal-window {
    background: #1e1e2e;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.5;
  }
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: #2d2d3a;
    border-bottom: 1px solid #3d3d4a;
  }
  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .terminal-dot--red { background: #ff5f57; }
  .terminal-dot--yellow { background: #ffbd2e; }
  .terminal-dot--green { background: #28c840; }
  .terminal-title {
    margin-left: auto;
    color: #8a8a9a;
    font-size: 11px;
    font-family: var(--font-sans);
  }
  .terminal-body {
    padding: 14px 16px;
    margin: 0;
    color: #cdd6f4;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre;
    background: transparent;
  }
  .terminal-body code {
    color: #cdd6f4;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  body.dark .terminal-window {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  /* Repo Info */
  .repo-meta {
    margin-bottom: var(--space-3);
  }
  .repo-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-ghost);
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
  }
  .repo-name {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }
  .repo-tagline {
    font-size: var(--text-lg);
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }
  .repo-description {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }
  .repo-differentiator {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-radius: 8px;
    border-left: 3px solid var(--color-accent);
    margin-bottom: var(--space-5);
    line-height: var(--leading-relaxed);
  }
  .repo-differentiator strong {
    color: var(--color-text);
  }

  /* Badges */
  .repo-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .repo-badge {
    height: 20px;
    display: inline-block;
  }

  /* Links */
  .repo-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .repo-links .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .repo-links .btn svg {
    flex-shrink: 0;
  }
</style>
