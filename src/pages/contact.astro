---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contact" description="Get in touch with TurinTech Solutions. Tell us about your project." page="contact">
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">Contact</span>
      <h1>Let's <span class="text-accent">talk</span></h1>
      <p class="page-header-sub">
        Tell us about your project and we'll figure out the best way forward. No pressure, no jargon.
      </p>
    </div>
  </section>

  <!-- Form -->
  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <ContactForm webhookUrl="http://100.106.72.45:3456/lead" />
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* --- Page Header --- */
  .page-header {
    padding: var(--space-16) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  .page-header-sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
  }

  .contact-layout {
    max-width: 640px;
  }
</style>
