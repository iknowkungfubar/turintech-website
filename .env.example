# TurinTech Solutions Website — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Contact form submission endpoint (e.g. a webhook or serverless function URL).
# If not set, the form shows a friendly message directing users to email instead.
# PUBLIC_WEBHOOK_URL=https://hook.example.com/submit

# Contact email shown in JSON-LD structured data (Organization schema).
# If not set, defaults to contact@turintechsolutions.com
# PUBLIC_CONTACT_EMAIL=hello@turintechsolutions.com
