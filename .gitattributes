# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Source files
*.astro text diff=html
*.css text diff=css
*.js text diff=js
*.ts text diff=ts
*.mjs text diff=js
*.jsx text
*.tsx text
*.scss text
*.json text diff=json
*.yml text diff=yaml
*.yaml text diff=yaml
*.md text diff=markdown
*.rst text
*.toml text
*.cfg text
*.ini text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Git files
.gitattributes text
.gitignore text

# Lock / generated files
*.lock -diff
bun.lock binary

# Binary / images
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg -text diff
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Editor files
*.swp binary
*.swo binary
